# Compose schema reference: 3.8
services:
  loki:
    image: grafana/loki:{{ monitoring_loki_version }}
    container_name: loki
    command: -config.file=/etc/loki/config.yml
    ports:
      - "{{ monitoring_loki_port }}:3100"
    volumes:
      - ./loki/config.yml:/etc/loki/config.yml:ro
      - loki-data:/loki
    labels:
      logging: "promtail"
      app: "loki"
      environment: {{ monitoring_environment_name | to_json }}
    networks:
      - logging
    healthcheck:
      test: ["CMD-SHELL", "wget --spider --quiet http://localhost:3100/ready || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    deploy:
      resources:
        limits:
          cpus: {{ monitoring_loki_cpu_limit | to_json }}
          memory: {{ monitoring_loki_memory_limit | to_json }}
        reservations:
          cpus: {{ monitoring_loki_cpu_reservation | to_json }}
          memory: {{ monitoring_loki_memory_reservation | to_json }}

  promtail:
    image: grafana/promtail:{{ monitoring_promtail_version }}
    container_name: promtail
    command: -config.file=/etc/promtail/config.yml
    ports:
      - "{{ monitoring_promtail_port }}:9080"
    volumes:
      - ./promtail/config.yml:/etc/promtail/config.yml:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    labels:
      logging: "promtail"
      app: "promtail"
      environment: {{ monitoring_environment_name | to_json }}
    networks:
      - logging
    depends_on:
      loki:
        condition: service_healthy
    deploy:
      resources:
        limits:
          cpus: {{ monitoring_promtail_cpu_limit | to_json }}
          memory: {{ monitoring_promtail_memory_limit | to_json }}
        reservations:
          cpus: {{ monitoring_promtail_cpu_reservation | to_json }}
          memory: {{ monitoring_promtail_memory_reservation | to_json }}

  grafana:
    image: grafana/grafana:{{ monitoring_grafana_version }}
    container_name: grafana
    ports:
      - "{{ monitoring_grafana_port }}:3000"
    environment:
      GF_AUTH_ANONYMOUS_ENABLED: "false"
      GF_SECURITY_ADMIN_USER: {{ monitoring_grafana_admin_user | to_json }}
      GF_SECURITY_ADMIN_PASSWORD: {{ monitoring_grafana_admin_password | to_json }}
      GF_SECURITY_ALLOW_EMBEDDING: "true"
    volumes:
      - grafana-data:/var/lib/grafana
      - ./grafana/provisioning:/etc/grafana/provisioning:ro
      - ./grafana/dashboards:/var/lib/grafana/dashboards:ro
    labels:
      logging: "promtail"
      app: "grafana"
      environment: {{ monitoring_environment_name | to_json }}
    networks:
      - logging
    depends_on:
      loki:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "wget --spider --quiet http://localhost:3000/api/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s
    deploy:
      resources:
        limits:
          cpus: {{ monitoring_grafana_cpu_limit | to_json }}
          memory: {{ monitoring_grafana_memory_limit | to_json }}
        reservations:
          cpus: {{ monitoring_grafana_cpu_reservation | to_json }}
          memory: {{ monitoring_grafana_memory_reservation | to_json }}

networks:
  logging:
    name: {{ monitoring_project_name | to_json }}

volumes:
  loki-data:
  grafana-data:
