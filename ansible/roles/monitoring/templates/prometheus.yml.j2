global:
  scrape_interval: {{ monitoring_prometheus_scrape_interval }}
  evaluation_interval: {{ monitoring_prometheus_evaluation_interval }}

scrape_configs:
{% for target in monitoring_prometheus_targets %}
  - job_name: {{ target.job | to_json }}
{% if target.path is defined %}
    metrics_path: {{ target.path | to_json }}
{% endif %}
    static_configs:
      - targets: {{ target.targets | to_json }}
{% endfor %}
